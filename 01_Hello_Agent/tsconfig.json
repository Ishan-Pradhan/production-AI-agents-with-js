{
    "compilerOptions": {
        "target": "es2022",
        "module": "esnext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "lib": ["es2022", "DOM"],
        "outDir": "dist",
        "rootDir": "src",
        "resolveJsonModule": true,
        "noEmit": true,
        "types": ["node"]
    },
    "include": ["src"],
    "exclude": ["node_modules", "dist"]
}